{
  "qwen3.5-flash": {
    "placeholders": [
      {
        "name": "target-model-name",
        "type": "string",
        "required": false,
        "default": "${@template.name}"
      }
    ],
    "metadata": {
      "recommended_service_provider_templates": [
        "aliyun-bailian"
      ],
      "website": "https://bailian.console.aliyun.com/cn-beijing/?tab=model#/model-market/detail/qwen3.5-flash"
    },
    "desc": "Qwen3.5系列Flash模型，支持文本、图像、视频输入与文本输出，面向低成本、高吞吐的通用多模态理解、推理和工具调用场景。",
    "config": {
      "desc": "${@template.desc}",
      "apiKey": "",
      "type": "text_generation",
      "publisher": "qwen",
      "metadata": {
        "public": {
          "abilities": {
            "abilities": [
              "tool",
              "reasoning",
              "enable_thinking",
              "structured_output",
              "responses_api"
            ],
            "input_modalities": [
              "text",
              "image",
              "video"
            ],
            "output_modalities": [
              "text"
            ]
          },
          "context": {
            "context_length": 1000000,
            "max_prompt_tokens": 991000,
            "max_completion_tokens": 64000
          },
          "pricing": {
            "prompt": "0.0000002",
            "completion": "0.000002",
            "request": "0",
            "image": "0",
            "web_search": "0.004",
            "internal_reasoning": "0",
            "input_cache_read": "0.00000002",
            "input_cache_write": "0.00000025",
            "unit": "CNY"
          },
          "model_name": "${@template.placeholders.target-model-name}"
        },
        "secret": {}
      }
    }
  }
}
