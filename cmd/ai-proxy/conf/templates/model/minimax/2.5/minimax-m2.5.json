              "reasoning",
              "tool"
            ],
            "input_modalities": [
              "text"
            ],
            "output_modalities": [
              "text"
            ]
          },
          "context": {
            "context_length": 204800,
            "max_prompt_tokens": 196608,
            "max_completion_tokens": 131072
          },
          "pricing": {
            "prompt": "0.0000021",
            "completion": "0.0000084",
            "request": "0",
            "image": "0",
            "web_search": "0",
            "internal_reasoning": "0",
            "input_cache_read": "0",
            "input_cache_write": "0",
            "unit": "CNY"
          },
          "model_name": "${@template.placeholders.target-model-name}"
        },
        "secret": {}
      }
    }
