{
  "minimax-m2.5": {
    "placeholders": [
      {
        "name": "target-model-name",
        "type": "string",
        "required": false,
        "mapping": {
          "by": {
            "service_provider_type": {
              "aliyun-bailian": "MiniMax-M2.5"
            }
          },
          "default": "MiniMax/MiniMax-M2.5"
        },
        "desc": "当服务提供商为阿里云百炼时：MiniMax-M2.5 调用的是部署在百炼上的模型服务；MiniMax/MiniMax-M2.5 则是在百炼上销售，但由 MiniMax 三方直供。"
      }
    ],
    "metadata": {
      "recommended_service_provider_templates": [
        "aliyun-bailian"
      ],
      "website": "https://bailian.console.aliyun.com/cn-beijing/?tab=model#/model-market/detail/MiniMax-M2.5"
    },
    "desc": "MiniMax-M2.5 是 MiniMax 推出的旗舰级开源大模型，经过数十万个真实复杂环境中的大规模强化学习训练，M2.5 在编程、工具调用和搜索、办公等生产力场景都达到或者刷新了行业的 SOTA。",
    "config": {
      "desc": "${@template.desc}",
      "apiKey": "",
